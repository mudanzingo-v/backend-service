# =============================================================================
# Mobbit Backend Service — environment variables
# Copy to .env and fill in. NEVER commit .env.
# =============================================================================

# --- App ---
APP_ENV=local                       # local | dev | staging | prod
APP_NAME=mobbit-backend-service
APP_HOST=0.0.0.0
APP_PORT=8765
APP_LOG_LEVEL=info                  # debug | info | warning | error

# --- Database ---
DATABASE_URL=postgresql+asyncpg://mobbit:mobbit@db:5432/mobbit
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false                 # log SQL queries

# --- Auth: AWS Cognito (JWT validation) ---
# Region and user pool IDs from infra-base-t/cognito.tf
AWS_REGION=us-west-2
COGNITO_USER_POOL_MOBBIT=us-west-2_1h3mHs8GJ     # B2C (mobbit-users)
COGNITO_USER_POOL_PROVIDERS=us-west-2_fwzhDEy8q  # Providers
COGNITO_USER_POOL_RCCM=us-west-2_M9NJljg8s        # Admin (rccm-users)
COGNITO_CLIENT_MOBBIT=client_mobbit
COGNITO_CLIENT_PROVIDERS=client_providers
COGNITO_CLIENT_RCCM=client_rccm
# In local/dev, set this to "false" to skip signature verification
# (still decodes the JWT and extracts claims). NEVER in prod.
AUTH_SKIP_VERIFICATION=false

# --- External services (read from .env, NOT from code) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
COPOMEX_API_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COPOMEX_API_URL=https://api.copomex.com
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_API_VERSION=2024-06-20

# --- Pricing model (mobbit fees, taxes) ---
# These were hardcoded in the Rust lambdas. They are now env vars
# so operations can change them without redeploy.
PRICING_MOBBIT_FEE=0.05
PRICING_IVA=0.16
PRICING_TRANSACTION_FEE=0.05
PRICING_CASH_ON_DELIVERY_PROVIDER_FEE=0.85
PRICING_CASH_ON_DELIVERY_MOBBIT_FEE=0.15

# --- CORS (allowed origins for the front) ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

